{
  "title": "Screening LLM — Observability",
  "tags": [
    "otel",
    "screening",
    "cadvisor"
  ],
  "schemaVersion": 39,
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timepicker": {},
  "panels": [
    {
      "title": "AI Server Traffic",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "id": 1,
      "title": "Requests per Second",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum by (method, path, status) (rate(ai_screening_requests_total[1m]))",
          "legendFormat": "{{method}} {{path}} [{{status}}]"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "rps",
          "custom": {
            "showPoints": "never"
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Request Duration (p99)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, method, path) (rate(ai_screening_request_duration_seconds_bucket[1m])))",
          "legendFormat": "{{method}} {{path}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "showPoints": "never"
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Active Requests",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "ai_screening_active_requests",
          "legendFormat": "active"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 16,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 5
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Error Rate (4xx/5xx)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(ai_screening_requests_total{status=~\"4..|5..\"}[1m])) / sum(rate(ai_screening_requests_total[1m]))",
          "legendFormat": "error ratio"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 20,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "showPoints": "never"
          },
          "min": 0,
          "max": 1
        }
      }
    },
    {
      "title": "AI Server Analysis",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "collapsed": false
    },
    {
      "id": 5,
      "title": "Analysis Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum by (model, provider, status) (rate(ai_screening_analysis_total[1m]))",
          "legendFormat": "{{model}} {{provider}} [{{status}}]"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "showPoints": "never"
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Analysis Duration (p99)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, model, provider) (rate(ai_screening_analysis_duration_seconds_bucket[1m])))",
          "legendFormat": "{{model}} {{provider}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "showPoints": "never"
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Image Throughput",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "rate(ai_screening_image_bytes_total[1m])",
          "legendFormat": "bytes/s"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "showPoints": "never"
          }
        }
      }
    },
    {
      "title": "Health & Resilience",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "collapsed": false
    },
    {
      "id": 8,
      "title": "Circuit Breaker State",
      "type": "state-timeline",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "ai_screening_circuit_breaker_state{name=\"ollama\"}",
          "legendFormat": "{{name}}"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 19
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "showPoints": "never"
          },
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "red",
                "value": 1
              },
              {
                "color": "orange",
                "value": 2
              }
            ]
          }
        }
      }
    },
    {
      "id": 9,
      "title": "Circuit Breaker Failures",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "ai_screening_circuit_breaker_failures{name=\"ollama\"}",
          "legendFormat": "{{name}} failures"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 19
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 3
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Last Analysis",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "time() - ai_screening_last_analysis_timestamp_seconds",
          "legendFormat": "seconds ago"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 19
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 300
              },
              {
                "color": "red",
                "value": 900
              }
            ]
          }
        }
      }
    },
    {
      "title": "Container Resources (cAdvisor)",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 25
      },
      "collapsed": false
    },
    {
      "id": 11,
      "title": "CPU Usage",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service=~\".+\"}[1m])",
          "legendFormat": "{{container_label_com_docker_compose_service}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 26
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cores",
          "custom": {
            "showPoints": "never"
          }
        }
      }
    },
    {
      "id": 12,
      "title": "Memory Usage",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{container_label_com_docker_compose_service=~\".+\"}",
          "legendFormat": "{{container_label_com_docker_compose_service}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 26
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "showPoints": "never"
          }
        }
      }
    },
    {
      "id": 13,
      "title": "Network I/O",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "rate(container_network_receive_bytes_total{container_label_com_docker_compose_service=~\".+\"}[1m])",
          "legendFormat": "{{container_label_com_docker_compose_service}} (rx)"
        },
        {
          "expr": "rate(container_network_transmit_bytes_total{container_label_com_docker_compose_service=~\".+\"}[1m])",
          "legendFormat": "{{container_label_com_docker_compose_service}} (tx)"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 26
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "showPoints": "never"
          }
        }
      }
    },
    {
      "id": 14,
      "title": "Disk I/O",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "rate(container_fs_writes_bytes_total{container_label_com_docker_compose_service=~\".+\"}[1m])",
          "legendFormat": "{{container_label_com_docker_compose_service}} (write)"
        },
        {
          "expr": "rate(container_fs_reads_bytes_total{container_label_com_docker_compose_service=~\".+\"}[1m])",
          "legendFormat": "{{container_label_com_docker_compose_service}} (read)"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 34
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "showPoints": "never"
          }
        }
      }
    },
    {
      "id": 15,
      "title": "Container Uptime",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "time() - container_start_time_seconds{container_label_com_docker_compose_service=~\".+\"}",
          "legendFormat": "{{container_label_com_docker_compose_service}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 34
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "showPoints": "never",
            "displayMode": "list"
          }
        }
      }
    },
    {
      "id": 16,
      "title": "Running Containers",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "count(container_start_time_seconds{container_label_com_docker_compose_service=~\".+\"})"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 34
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "title": "Distributed Tracing & Logs",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 42
      },
      "collapsed": false
    },
    {
      "id": 17,
      "title": "Recent Traces",
      "type": "table",
      "datasource": {
        "type": "jaeger",
        "uid": "jaeger"
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 43
      },
      "targets": [
        {
          "service": "ai-server",
          "queryType": "search",
          "limit": 20
        }
      ]
    },
    {
      "id": 18,
      "title": "Recent Logs",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 43
      },
      "targets": [
        {
          "expr": "{service_name=~\"ai-server|macos-screening-assistant\"} |= ``",
          "legendFormat": ""
        }
      ]
    }
  ]
}
